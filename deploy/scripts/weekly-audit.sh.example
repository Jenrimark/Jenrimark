#!/usr/bin/env bash
# cron 示例: 每周一 03:00 依赖审计并触发部署
# 0 3 * * 1 /path/to/repo/deploy/scripts/weekly-audit.sh.example

set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$REPO_ROOT"

npm audit fix --audit-level=moderate || true
git diff --quiet package-lock.json || {
  git add package-lock.json
  git commit -m "chore: npm audit fix [skip ci]" || true
  git push origin main
}
