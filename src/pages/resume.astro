---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageHeader from '../components/PageHeader.astro';
import Timeline from '../components/Timeline.astro';
import SkillBar from '../components/SkillBar.astro';
import { site } from '../site.config';
import { profile } from '../data/profile';
---

<BaseLayout title={`简历 — ${site.name}`} description={`${site.author} 的简历`}>
  <SiteHeader />
  <div class="page-content">
    <PageHeader label="我的简历" title="工作与教育经历" lead={`${profile.fullName} · ${profile.tagline}`} />

    <div class="resume-grid">
      <Timeline title="💼 工作经历" items={profile.timeline.work} />
      <Timeline title="🎓 教育背景" items={profile.timeline.education} />
    </div>

    <Timeline title="🏆 荣誉奖项" items={profile.timeline.awards} />

    <SkillBar skills={profile.skills} />

    <section class="page-block page-block--prose">
      <h2 class="page-block__title">自我评价</h2>
      <p>{profile.selfEval}</p>
    </section>
  </div>
  <SiteFooter />
</BaseLayout>
