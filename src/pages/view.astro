---
import ViewLayout from '../layouts/ViewLayout.astro';
import ViewTile from '../components/view/ViewTile.astro';
import { site } from '../site.config';
import { searchEngines } from '../data/view-search';
---

<ViewLayout title={`View — ${site.name}`}>
  <div class="view-page">
    <a href="/" class="view-back">← {site.name}</a>

    <div class="view-grid">
      <!-- 大 tile：问候 + 搜索 + 引擎 -->
      <ViewTile span="full" strong liquid class="view-tile-search">
        <h1 class="view-greeting" id="view-greeting">你好</h1>

        <div class="view-search-box">
          <form id="view-search-form" class="view-search-form" role="search">
            <input
              id="view-search-input"
              class="view-search-input"
              type="search"
              name="q"
              autocomplete="off"
              autocapitalize="off"
              spellcheck="false"
              placeholder="搜索或输入网址"
              aria-label="搜索"
              aria-expanded="false"
              aria-controls="view-suggest"
              aria-autocomplete="list"
            />
            <button type="submit" class="view-search-submit view-chip view-chip--solid" aria-label="搜索">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                <path d="M18.031 16.6168L22.3137 20.8995L20.8995 22.3137L16.6168 18.031C15.0769 19.263 13.124 20 11 20C6.032 20 2 15.968 2 11C2 6.032 6.032 2 11 2C15.968 2 20 6.032 20 11C20 13.124 19.263 15.0769 18.031 16.6168ZM16.0247 15.8748C17.2475 14.6146 18 12.8956 18 11C18 7.1325 14.8675 4 11 4C7.1325 4 4 7.1325 4 11C4 14.8675 7.1325 18 11 18C12.8956 18 14.6146 17.2475 15.8748 16.0247L16.0247 15.8748Z"></path>
              </svg>
            </button>
          </form>
          <ul id="view-suggest" class="view-suggest" role="listbox" hidden></ul>
        </div>

        <div id="view-engines" class="view-engines" role="group" aria-label="搜索引擎">
          {
            searchEngines.map((engine) => (
              <button
                type="button"
                class="view-chip view-engine"
                data-engine={engine.id}
                aria-pressed={engine.default ? 'true' : 'false'}
              >
                {engine.label}
              </button>
            ))
          }
        </div>
      </ViewTile>

      <!-- 中 tile：扩展 -->
      <ViewTile class="view-tile-ext" id="view-ext-banner" aria-label="扩展安装">
        <div class="view-ext-banner__main">
          <div class="view-ext-banner__text">
            <strong>书签同步</strong>
            <span>安装 Chrome 扩展</span>
          </div>
          <a
            class="view-chip view-chip--solid view-ext-download"
            href="/downloads/jenrimark-view-extension.zip"
            download="jenrimark-view-extension.zip"
          >
            下载
          </a>
        </div>
        <details class="view-ext-install">
          <summary>安装步骤</summary>
          <ol>
            <li>下载并解压 zip</li>
            <li>Chrome → <code>chrome://extensions</code> → 开发者模式</li>
            <li>加载已解压的扩展程序</li>
            <li>刷新本页</li>
          </ol>
        </details>
      </ViewTile>

      <!-- 中 tile：控制 -->
      <ViewTile class="view-tile-controls">
        <time id="view-clock" class="view-clock" datetime=""></time>
        <div class="view-control-row">
          <button
            type="button"
            id="view-theme-toggle"
            class="view-chip view-chip--round view-theme-toggle"
            aria-label="主题：自动"
            title="主题：自动（点击切换）"
            data-theme-mode="auto"
          >
            <span class="view-theme-toggle__icon" aria-hidden="true"></span>
          </button>
          <button
            type="button"
            id="view-bg-toggle"
            class="view-chip"
            aria-expanded="false"
            aria-controls="view-bg-panel"
          >
            壁纸
          </button>
        </div>

        <div id="view-bg-panel" class="view-bg-panel" hidden>
          <button type="button" id="view-bg-dropzone" class="view-bg-dropzone view-chip view-chip--dashed">
            <span id="view-bg-dropzone-preview" class="view-bg-dropzone__preview" hidden></span>
            <span id="view-bg-dropzone-icon" class="view-bg-dropzone__icon">+</span>
            <span id="view-bg-dropzone-text" class="view-bg-dropzone__text">点击或拖入图片</span>
          </button>
          <input id="view-bg-upload" type="file" accept="image/*" hidden />
          <div class="view-bg-custom-actions">
            <button type="button" id="view-bg-default-btn" class="view-chip">恢复默认</button>
            <button type="button" id="view-bg-clear-custom" class="view-chip" hidden>删除图片</button>
          </div>
          <div id="view-bg-dim-wrap" class="view-bg-dim-control" hidden>
            <label for="view-bg-dim">暗化</label>
            <input id="view-bg-dim" type="range" min="0" max="0.85" step="0.05" value="0.15" />
            <span id="view-bg-dim-value" class="view-bg-dim-value">15%</span>
          </div>
        </div>
      </ViewTile>

      <!-- 大 tile：书签 -->
      <ViewTile span="full" strong class="view-tile-bookmarks" aria-label="书签">
        <div class="view-toolbar">
          <div>
            <h2 class="view-toolbar__title">书签</h2>
            <p id="view-status" class="view-status">加载中…</p>
          </div>
          <div class="view-toolbar-actions">
            <button type="button" id="view-folder-toggle" class="view-chip" aria-expanded="false">
              筛选
            </button>
            <button type="button" id="view-folder-select-all" class="view-chip">全选</button>
            <button type="button" id="view-folder-clear" class="view-chip">全部</button>
          </div>
        </div>

        <div id="view-folder-panel" class="view-folder-panel">
          <p class="view-folder-panel__hint">勾选要显示的文件夹；不选或全选则显示全部。</p>
          <div id="view-folder-list" class="view-folder-list"></div>
        </div>

        <div id="view-bookmarks" class="view-bookmarks">
          <p class="view-empty view-chip view-chip--dashed">正在加载书签…</p>
        </div>
      </ViewTile>
    </div>
  </div>
</ViewLayout>

<script>
  import '../scripts/view-page';

  const greetEl = document.getElementById('view-greeting');
  if (greetEl) {
    const h = new Date().getHours();
    let text = '晚上好';
    if (h < 6) text = '夜深了';
    else if (h < 12) text = '早上好';
    else if (h < 14) text = '中午好';
    else if (h < 18) text = '下午好';
    greetEl.textContent = text;
  }
</script>
