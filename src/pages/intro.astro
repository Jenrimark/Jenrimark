---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageHeader from '../components/PageHeader.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import InfoTable from '../components/InfoTable.astro';
import { site } from '../site.config';
import { profile } from '../data/profile';
---

<BaseLayout title={`简介 — ${site.name}`} description={`关于 ${site.author}`}>
  <SiteHeader />
  <div class="page-content">
    <PageHeader label="关于我" title={profile.fullName} lead={profile.tagline} />
    <p class="page-intro">{profile.intro}</p>
    <p class="page-subtitle">{profile.subtitle}</p>

    <FeaturedProject {...profile.featuredProject} />

    <section class="page-block">
      <h2 class="page-block__title">我能提供什么</h2>
      <FeatureGrid items={profile.features} />
    </section>

    <InfoTable items={profile.info} />
  </div>
  <SiteFooter />
</BaseLayout>
