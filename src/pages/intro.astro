---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { site } from '../site.config';
---

<BaseLayout title={`简介 — ${site.name}`} description={`关于 ${site.author}`}>
  <SiteHeader />
  <article class="prose">
    <h1>简介</h1>
    <p class="meta">{site.description}</p>
    <p>
      我是 <strong>{site.author}</strong>，一名开发者。这个站点用来展示个人简介、简历、项目与联系方式。
    </p>
    <p>
      技术栈以 Web 为主：静态站点（Astro）、自动化部署（GitHub Actions + Webhook）、家里 Windows 机器 + Nginx + frp 公网穿透。
    </p>
    <h2>现在在做什么</h2>
    <ul>
      <li>写代码、做 side project</li>
      <li>维护个人站点与部署流水线</li>
      <li>偶尔写博客（见 <a href="/blog/">/blog/</a>）</li>
    </ul>
  </article>
  <SiteFooter />
</BaseLayout>
