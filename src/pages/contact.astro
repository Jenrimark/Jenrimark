---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { site } from '../site.config';
---

<BaseLayout title={`联系 — ${site.name}`} description={`联系 ${site.author}`}>
  <SiteHeader />
  <article class="prose">
    <h1>联系</h1>
    <p class="meta">欢迎通过以下方式联系</p>
    <ul>
      <li><a href={site.social.email}>Email</a></li>
      <li><a href={site.social.github} target="_blank" rel="noopener noreferrer">GitHub</a></li>
    </ul>
    <p>邮箱与社交链接在 <code>src/site.config.ts</code> 的 <code>social</code> 字段中配置。</p>
  </article>
  <SiteFooter />
</BaseLayout>
