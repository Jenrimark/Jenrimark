---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import BentoGrid from '../components/BentoGrid.astro';
import BentoCard from '../components/BentoCard.astro';
import { site } from '../site.config';
---

<BaseLayout title={site.title} description={site.description}>
  <SiteHeader />
  <BentoGrid>
    <BentoCard
      label="主页"
      title={`我是 ${site.author}`}
      description={site.description}
      span={2}
      tall
      largeTitle
    />
    <BentoCard
      label="简介"
      title="关于我"
      description="背景、方向与现在在做什么"
      href="/intro/"
      tall
    />
    <BentoCard
      label="简历"
      title="经历与技能"
      description="工作、教育与能力概览"
      href="/resume/"
    />
    <BentoCard
      label="项目"
      title="开源 & 实验"
      description="仓库、side project 与作品"
      href="/projects/"
      span={2}
    />
    <BentoCard
      label="联系"
      title="打个招呼"
      description="邮箱与社交链接"
      href="/contact/"
    />
  </BentoGrid>
  <SiteFooter />
</BaseLayout>
