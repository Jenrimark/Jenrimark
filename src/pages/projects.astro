---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageHeader from '../components/PageHeader.astro';
import ProjectSection from '../components/ProjectSection.astro';
import { site } from '../site.config';
import { profile } from '../data/profile';
---

<BaseLayout title={`项目 — ${site.name}`} description={`${site.author} 的项目与开源`}>
  <SiteHeader />
  <div class="page-content page-panel">
    <PageHeader
      label="项目资源库"
      title="作品与实验"
      lead="开源仓库、可视化项目与实用工具集合"
    />

    {
      profile.projectSections.map((section) => (
        <ProjectSection title={section.title} projects={section.projects} />
      ))
    }

    <p class="page-note">
      更多仓库见 <a href={site.social.github}>GitHub</a>；项目数据在 <code>src/data/profile.ts</code> 中维护。
    </p>
  </div>
  <SiteFooter />
</BaseLayout>
