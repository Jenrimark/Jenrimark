---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { site } from '../site.config';
---

<BaseLayout title={`关于 — ${site.name}`} description={`关于 ${site.author}`}>
  <SiteHeader />
  <article class="prose">
    <h1>关于</h1>
    <p class="meta">个人站点 MVP · Astro + Nginx + frp</p>
    <p>
      这是 <strong>{site.author}</strong> 的个人网站。架构刻意保持轻量：本地写 Markdown，<code>git push</code> 后由
      CI 校验后由家里 Webhook 拉代码并构建，Nginx 托管 <code>dist/</code>，frp 负责公网穿透。
    </p>
    <h2>链接</h2>
    <ul>
      <li><a href={site.social.github}>GitHub</a></li>
      <li><a href={site.social.email}>Email</a></li>
    </ul>
    <h2>维护</h2>
    <p>站点配置集中在 <code>src/site.config.ts</code>。文章放在 <code>src/content/blog/</code>。部署说明见 <code>docs/Windows-Git自动部署.md</code>。</p>
  </article>
  <SiteFooter />
</BaseLayout>
