---
interface Props {
  name: string;
  badge?: string;
  description: string;
  href: string;
  stars?: string;
  forks?: string;
  meta?: string;
}

const { name, badge, description, href, stars, forks, meta } = Astro.props;
---

<a class="featured-project" href={href} target="_blank" rel="noopener noreferrer">
  <div class="featured-project__inner">
    <div class="featured-project__main">
      <div class="featured-project__icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
      </div>
      <div>
        <div class="featured-project__title-row">
          <h2 class="featured-project__name">{name}</h2>
          {badge && <span class="featured-project__badge">{badge}</span>}
        </div>
        <p class="featured-project__desc">{description}</p>
      </div>
    </div>
    {
      (stars || forks) && (
        <div class="featured-project__stats">
          {stars && (
            <div class="featured-project__stat">
              <span class="featured-project__stat-value">★ {stars}</span>
              <span class="featured-project__stat-label">Stars</span>
            </div>
          )}
          {forks && (
            <div class="featured-project__stat">
              <span class="featured-project__stat-value">⑂ {forks}</span>
              <span class="featured-project__stat-label">Forks</span>
            </div>
          )}
        </div>
      )
    }
  </div>
  {meta && <p class="featured-project__meta">{meta}</p>}
</a>
